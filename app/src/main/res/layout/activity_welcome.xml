<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Card utama -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:layout_centerInParent="true"
        android:elevation="8dp">

        <!-- Title kecil -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang!"
            android:textColor="#111827"
            android:textSize="26sp"
            android:textStyle="bold"/>

        <!-- Judul -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="di Pengingat Minum Obat"
            android:textColor="#6FA8DC"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aplikasi pengingat obat untuk membantu kamu minum obat tepat waktu dan menjaga kesehatan."
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <!-- Gambar -->
        <ImageView
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/doctor"
            android:scaleType="centerInside"
            android:layout_marginTop="16dp"/>

        <!-- Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMulai"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Mari Mulai"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:background="@drawable/btn_gradient"/>

    </LinearLayout>

</RelativeLayout>